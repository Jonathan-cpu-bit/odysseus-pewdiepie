{
  "build": {
    "distDir": "../ui",
    "devPath": "../ui"
  },
  "package": {
    "productName": "Odysseus",
    "version": "0.1.0"
  },
  "tauri": {
    "allowlist": {
      "all": true
    },
    "bundle": {
      "active": true,
      "targets": "all",
      "identifier": "com.odysseus.app",
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.icns",
        "icons/icon.ico"
      ]
    },
    "systemTray": {
      "iconPath": "icons/32x32.png",
      "iconAsTemplate": true
    },
    "windows": [
      {
        "title": "Odysseus",
        "width": 1280,
        "height": 850,
        "resizable": true,
        "fullscreen": false,
        "visible": false
      }
    ]
  }
}